# ===== Binance API =====
# 去 Binance Futures Demo/Testnet 生成测试网 API Key，不要先用实盘 Key。
BINANCE_API_KEY=replace_with_your_testnet_api_key
BINANCE_API_SECRET=replace_with_your_testnet_api_secret

# 2026 USD-M Futures Demo/Testnet REST base URL
BINANCE_BASE_URL=https://demo-fapi.binance.com
# 实盘才使用：
# BINANCE_BASE_URL=https://fapi.binance.com

# v6.5.0+ exchange adapter: binance | okx (okx = read-only preflight in v6.5.1)
EXCHANGE=binance

# ===== OKX API (v6.5.1 read-only preflight; EXCHANGE=okx 时必填) =====
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_API_PASSPHRASE=
# OKX_BASE_URL=https://www.okx.com
# OKX_SIMULATED_TRADING=false
# OKX_DEFAULT_INST_ID=BTC-USDT-SWAP
# OKX_INST_TYPE=SWAP
# OKX_ALLOWED_INST_IDS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP
# OKX_READONLY_MODE=true
# OKX_LIVE_TRADING_ENABLED=false
# OKX_CONFIRM_PHRASE=
# OKX_EXPECTED_CONFIRM_PHRASE=I_UNDERSTAND_THIS_IS_REAL_MONEY
# OKX_REQUIRE_ONE_SHOT=true
# OKX_FORCE_RUNTIME_LOCKED_ON_STARTUP=true
# OKX_CANARY_MODE=true
# OKX_TD_MODE=isolated
# OKX_MAX_RISK_USDT=1
# OKX_MAX_MARGIN_USDT=20
# OKX_MAX_NOTIONAL_USDT=100

# ===== Webhook 安全密钥：自己随机生成，不是 TradingView 或 Binance 提供 =====
WEBHOOK_SECRET=replace_with_a_long_random_secret

# ===== 安全开关 =====
# false：只打印计划，不向币安提交订单；true：真的向 BINANCE_BASE_URL 提交订单
ENABLE_TRADING=false

# 只允许这些交易对，逗号分隔；留空表示不限制，不建议留空
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# 默认使用单向持仓 One-way Mode；本项目不支持 Hedge Mode
POSITION_MODE=ONE_WAY

# 数据库与日志
SQLITE_PATH=signals.db
LOG_LEVEL=INFO

# ===== Risk-based sizing / 自动风控仓位 =====
# 读取哪个资产余额，单资产模式一般是 USDT
RISK_BALANCE_ASSET=USDT
# fixed_pct 模式按哪个字段算账户余额：availableBalance 更保守；balance 包含未实现盈亏等
RISK_BALANCE_FIELD=availableBalance
# risk 模式如果 TradingView 没传 margin_usdt，则默认最多使用可用余额的 20% 作为保证金预算
AUTO_MARGIN_BALANCE_PCT=0.20
# 自动计算杠杆时的机器人上限；最终还会受币安交易对档位限制
MAX_AUTO_LEVERAGE=20
# 如果测试网读不到实际手续费，用这个 taker 费率兜底；0.0005 = 0.05%
DEFAULT_TAKER_FEE_RATE=0.0005
# 手续费安全垫；1.10 表示手续费估算多加 10%
FEE_SAFETY_MULTIPLIER=1.10

# ===== Existing-position handling / 已有持仓处理 =====
# replace：先取消旧委托/条件单，平掉当前持仓，再开新仓。推荐默认值。
# reverse_only：只在方向相反时平旧仓再开新仓；同向信号会跳过。
# ignore_same_side：同向信号跳过，反向信号平旧仓再开新仓。
# add：保留旧仓并继续开新仓，谨慎使用。
DEFAULT_POSITION_POLICY=replace

# ===== V4 Entry execution / 进场方式 =====
# 是否允许市价/限价进场。可以作为全局安全开关。
ALLOW_MARKET_ENTRY=true
ALLOW_LIMIT_ENTRY=true
# TradingView 没传 entry_type 时的默认进场方式：market 或 limit。
DEFAULT_ENTRY_TYPE=market
# 限价单等待成交秒数；超时会撤单。
DEFAULT_LIMIT_TIMEOUT_SEC=60
# 限价单超时未成交时，是否自动改市价进场。建议测试阶段 false。
DEFAULT_LIMIT_FALLBACK_TO_MARKET=false
# 市价进场最大允许滑点百分比。只有 JSON 里传 signal_price 时才会检查；0.30 = 0.30%。
DEFAULT_MAX_SLIPPAGE_PCT=0.30
# 限价单成交状态轮询间隔秒数。
LIMIT_POLL_INTERVAL_SEC=2
# Binance 签名接口有效窗口，建议 30000，降低新电脑时间小偏差导致 -1021 的概率。
RECV_WINDOW=30000
REQUEST_TIMEOUT=10


# ===== V5 Dashboard / 只读展示页面 =====
# 是否启用 Dashboard
DASHBOARD_ENABLED=false

# 是否要求 Dashboard Token
DASHBOARD_REQUIRE_TOKEN=true

# Dashboard 访问密钥；启用 Dashboard 时必须设置
DASHBOARD_TOKEN=

# Dashboard 默认刷新间隔，单位秒；0 表示不自动刷新
DASHBOARD_AUTO_REFRESH_SEC=10

# 是否对原始 journal/stats API 启用 Token 保护（复用 DASHBOARD_TOKEN）
PROTECT_JOURNAL_API=false
PROTECT_STATS_API=false

# ===== V5 Runtime Control / 运行锁定 =====
# 是否启用运行锁定（锁定后 webhook 跳过执行并写 journal）
RUNTIME_CONTROL_ENABLED=false
# 是否要求 Runtime Control Token
RUNTIME_CONTROL_REQUIRE_TOKEN=true
# 运行控制写操作密钥（lock/unlock）；与 DASHBOARD_TOKEN 分离
RUNTIME_CONTROL_TOKEN=
# 读 status/events 时是否也允许 DASHBOARD_TOKEN（仅读，不能 lock/unlock）
RUNTIME_STATUS_ALLOW_DASHBOARD_TOKEN=true

# ===== V5.9 TradingView Signal Sandbox / TV 信号沙盒 =====
# 启用后，对识别为 TradingView 的信号进行沙盒校验（只允许 demo/testnet）
TV_SIGNAL_SANDBOX_ENABLED=true
# 是否要求 JSON 必须包含 source 字段
TV_SIGNAL_REQUIRE_SOURCE=true
# 允许的 source 值，逗号分隔
TV_SIGNAL_ALLOWED_SOURCES=tradingview,tv_sandbox
# TV 信号 signal_id 必须以该前缀开头
TV_SIGNAL_ID_PREFIX=TV-
# TV 信号 risk_usdt 上限
TV_SIGNAL_MAX_RISK_USDT=5
# TV 信号 margin_usdt 上限
TV_SIGNAL_MAX_MARGIN_USDT=100
# 允许的 entry_type，逗号分隔
TV_SIGNAL_ALLOWED_ENTRY_TYPES=market,limit
# 非 demo/testnet endpoint 时拒绝 TV 信号
TV_SIGNAL_REJECT_LIVE_BINANCE=true

# ===== V6.4 TradingView Production Readiness =====
# 要求 TV 信号显式携带 position_strategy: replace/reject/add
TV_SIGNAL_REQUIRE_POSITION_STRATEGY=true
# 信号最大允许年龄（秒），配合 TV_SIGNAL_REJECT_EXPIRED 使用
TV_SIGNAL_MAX_AGE_SECONDS=300
# 是否强制要求 timestamp/sent_at/time（旧 Pine 可先 false）
TV_SIGNAL_REQUIRE_TIMESTAMP=false
# 是否拒绝过期信号
TV_SIGNAL_REJECT_EXPIRED=true
# tps.qty_pct 合计允许范围
TV_SIGNAL_TP_QTY_SUM_MIN=0.95
TV_SIGNAL_TP_QTY_SUM_MAX=1.05
# 最大 TP 档位数
TV_SIGNAL_MAX_TP_COUNT=5
# SL/TP 相对参考价最小距离（百分比，对应 Pine webhookMinSlBufferPct）
TV_SIGNAL_MIN_STOP_PCT=0.25
TV_SIGNAL_MIN_TP_PCT=0.25
# 方向正确但 SL/TP 距离过近时自动推远到 min + buffer
TV_SIGNAL_AUTO_NORMALIZE_GUARD_PRICES=true
# 在最小距离基础上额外增加的百分点（0.25% + 0.05% = 0.30%）
TV_SIGNAL_GUARD_DISTANCE_BUFFER_PCT=0.05
# 距离边界浮点容差
TV_SIGNAL_DISTANCE_EPSILON=0.000001

# ===== V6.0 TradingView Alert Observation / TV 接入观察 =====
# 是否启用 TV 连续运行观察
TV_ALERT_OBSERVATION_ENABLED=true
# TradingView Webhook 公网基址（不含 /tradingview），例如 https://xxxx.ngrok-free.app
TV_ALERT_PUBLIC_BASE_URL=
# 超过该分钟数未收到 TV 信号则 stale WARN
TV_ALERT_STALE_MINUTES=120
# Dashboard 默认观察窗口（小时）
TV_ALERT_OBSERVATION_WINDOW_HOURS=24
# 连续失败 WARN / ERROR 阈值
TV_ALERT_CONSECUTIVE_FAILURE_WARN=2
TV_ALERT_CONSECUTIVE_FAILURE_ERROR=3
# 演练预期覆盖的交易对
TV_ALERT_EXPECTED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# ===== V6.2 TradingView Cloud Alert Audit / TV 云端 Alert 审计 =====
# 是否启用 TV 云端 Alert 安全审计（只读，不影响 webhook 执行）
TV_CLOUD_AUDIT_ENABLED=true
# 审计统计窗口（小时）
TV_CLOUD_AUDIT_WINDOW_HOURS=24
# 重复 signal_id WARN 阈值（窗口内额外重复次数）
TV_CLOUD_DUPLICATE_SIGNAL_WARN=1
# 401 未授权 WARN 阈值（v6.2 未持久化 401，字段预留）
TV_CLOUD_UNAUTHORIZED_WARN=3
# skip_reason=tv_payload_invalid WARN 阈值
TV_CLOUD_PAYLOAD_INVALID_WARN=3
# Runtime Lock 拦截 WARN 阈值
TV_CLOUD_RUNTIME_LOCK_WARN=3

# ===== V6.4.4 Live Canary Safety Guards =====
# 仅在 Binance live/mainnet endpoint 生效；demo 环境不受影响
LIVE_TRADING_ENABLED=false
LIVE_CONFIRM_PHRASE=
LIVE_EXPECTED_CONFIRM_PHRASE=I_UNDERSTAND_THIS_IS_REAL_MONEY
LIVE_ALLOWED_SYMBOLS=BTCUSDT
LIVE_MAX_RISK_USDT=1
LIVE_MAX_MARGIN_USDT=20
LIVE_MAX_POSITION_NOTIONAL_USDT=100
LIVE_REQUIRE_ONE_SHOT=true
LIVE_REJECT_TRADINGVIEW_BY_DEFAULT=true
LIVE_FORCE_RUNTIME_LOCKED_ON_STARTUP=true
LIVE_CANARY_MODE=true